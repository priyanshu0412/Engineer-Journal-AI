# ─────────────────────────────────────────────────────────────
# DevTrack AI — Example Environment Variables (.env.example)
# Copy this file to `.env.local` or `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# ── General App Config
NEXT_PUBLIC_MOCK_MODE=false
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Database (MongoDB Atlas)
# Get connection string from https://cloud.mongodb.com
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/"

# ── Authentication (Clerk)
# Get keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ── AI Provider Configuration
# Set to "gemini" (Google) or "claude" (Anthropic)
AI_PROVIDER="gemini"

# Google Gemini (when AI_PROVIDER=gemini)
# Get API key from https://aistudio.google.com/apikey
GEMINI_API_KEY="AIzaSy..."
GEMINI_MODEL="gemini-2.5-flash"

# Anthropic Claude (when AI_PROVIDER=claude)
# Get API key from https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-xxx"
ANTHROPIC_MODEL="claude-opus-4-8"

# ── Email Configuration (Resend)
# Get API key from https://resend.com
RESEND_API_KEY="re_xxxxxxxxx"
# Must be a verified sender domain in Resend
RESEND_FROM_EMAIL="notifications@send.priyanshudev.site"

# ── Cron Job Security
# A shared secret protecting the cron API endpoints from unauthorized calls.
# Set this to a long random secret and provide it as `Authorization: Bearer <secret>`
# in Vercel Cron settings or as `x-cron-secret` request header.
CRON_SECRET="change-me-to-a-long-random-string"
